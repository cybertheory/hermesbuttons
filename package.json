{
  "name": "hermesbuttons",
  "version": "1.1.1",
  "description": "Drop-in \"Run on Hermes\" and \"Run on Hermes Skills\" buttons for any website or framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.js"
    }
  },
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hermes",
    "hermes-agent",
    "ai-agent",
    "self-improving",
    "persistent-memory",
    "openclaw",
    "button",
    "web-component",
    "deploy-button"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
